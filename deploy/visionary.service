[Unit]
Description=Visionary server (LLM plot description)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=visionary
Group=visionary
EnvironmentFile=/etc/visionary/env
ExecStart=/usr/local/bin/visionary-server -config /etc/visionary/config.json
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
Restart=on-failure
RestartSec=2s
StateDirectory=visionary
CacheDirectory=visionary

[Install]
WantedBy=multi-user.target
